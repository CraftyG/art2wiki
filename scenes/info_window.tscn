[node name="Label" type="Label" parent="PanelContainer/VBoxContainer/MarginContainer/ScrollContainer/MarginContainer/VBoxContainer" unique_id=1832697677]
custom_minimum_size = Vector2(275, 0)
layout_mode = 2
text = "Abnormals Registry Tag to Wikitext Converter (or ART2WIKI) is a quick tool made for assisting documentation on the many registry tags the mods from Team Abnormals  provide. It reads each tag file stored in a folder and converts the data into formatted text that can be used for the Team Abnormals Wiki."
label_settings = SubResource("LabelSettings_qgsps")
autowrap_mode = 2

[node name="Tab2Title" type="PanelContainer" parent="PanelContainer/VBoxContainer/MarginContainer/ScrollContainer/MarginContainer/VBoxContainer" unique_id=1494366165]
