[node name="Label" type="Label" parent="PanelContainer/VBoxContainer/MarginContainer/ScrollContainer/MarginContainer/VBoxContainer/Tab2Title" unique_id=769317706]
layout_mode = 2
text = "HOW TO USE"
horizontal_alignment = 1

[node name="Label2" type="Label" parent="PanelContainer/VBoxContainer/MarginContainer/ScrollContainer/MarginContainer/VBoxContainer" unique_id=1093615809]
custom_minimum_size = Vector2(270, 0)
layout_mode = 2
text = "1. Set up paths to a folder containing the tag files, and a .txt file for the formatted text to be stored.
2. Type in the Mod's ID and, if needed, the middle directory. They must be inputted as valid identifiers (Hover over the settings for more info).
3. Click \"Convert Files\". ART2WIKI will skip any invalid files found inside the folder, as well as only listing valid entries from each file.
4. Once conversion is complete, the output file is ready for use. Note that there's placeholder text for the description of each tag. Replace them accordingly during documenting."
label_settings = SubResource("LabelSettings_2rxvn")
autowrap_mode = 3

